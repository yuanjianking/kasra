# Kasra Application Configuration
# Copy to .env and modify

# Database
DATABASE_URL=sqlite:///./data/kasra.db
# DATABASE_URL=postgresql://user:password@localhost:5432/kasra

# Server
HOST=0.0.0.0
PORT=8080
WORKERS=4

# Security
API_KEY=dev-api-key-change-in-production
JWT_SECRET=change-this-to-a-random-secret

# SDK Configuration
KASRA_ENGINE__MAX_CONCURRENT_RULES=20
KASRA_AUDIT__ENABLED=true
KASRA_AUDIT__JSONL_PATH=./data/kasra-audit.jsonl

# Proxy upstream targets (comma-separated)
PROXY_TARGETS=api.anthropic.com,api.openai.com

# Logging
LOG_LEVEL=info
