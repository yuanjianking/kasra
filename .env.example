# Kasra Application Configuration
# Copy to .env and modify
# NOTE: All variables use KASRA_APP_ prefix (pydantic-settings requirement)
#
# IMPORTANT: PostgreSQL is REQUIRED. SQLite is NOT supported.

# Database (PostgreSQL only)
# Format: postgresql+psycopg2://user:password@host:5432/database
KASRA_APP_DATABASE_URL=postgresql+psycopg2://kasra:kasra@localhost:5432/kasra

# Server
KASRA_APP_HOST=0.0.0.0
KASRA_APP_PORT=8080
KASRA_APP_LOG_LEVEL=info

# Security — CHANGE THESE IN PRODUCTION
KASRA_APP_API_KEY=dev-api-key-change-in-production
KASRA_APP_JWT_SECRET=change-this-to-a-random-secret

# HTTPS CONNECT proxy (opt-in, disabled by default)
# KASRA_APP_HTTPS_PROXY_ENABLED=true
# KASRA_APP_HTTPS_PROXY_PORT=8443

# Rate limiting
KASRA_APP_RATE_LIMIT_RPM=120

# CORS (set specific origins in production)
# KASRA_APP_ALLOWED_ORIGINS='["https://kasra.example.com"]'

# Audit
KASRA_APP_AUDIT_RETENTION_DAYS=90

# Proxy upstream targets (comma-separated)
KASRA_APP_PROXY_TARGETS=api.anthropic.com,api.openai.com,api.deepseek.com

# SDK engine configuration
KASRA_ENGINE__MAX_CONCURRENT_RULES=20
KASRA_AUDIT__ENABLED=true
KASRA_AUDIT__JSONL_PATH=./data/kasra-audit.jsonl
