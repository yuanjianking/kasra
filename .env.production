# =============================================================================
# Kasra — Production Environment Configuration
# =============================================================================
# Usage:
#   cp .env.production /etc/kasra/kasra.env
#   chmod 600 /etc/kasra/kasra.env
#   chown kasra:kasra /etc/kasra/kasra.env
#
# NOTE: All variables use KASRA_APP_ prefix (pydantic-settings requirement)
#       Systemd reads this via EnvironmentFile=/etc/kasra/kasra.env
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Must set before starting
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection (REQUIRED for production)
# Format: postgresql+psycopg2://user:password@host:5432/database
KASRA_APP_DATABASE_URL=postgresql+psycopg2://kasra:CHANGE_ME@127.0.0.1:5432/kasra

# API key for authentication (CHANGE THIS)
KASRA_APP_API_KEY=generate-a-random-64-char-key-here-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# JWT secret for session signing (CHANGE THIS)
KASRA_APP_JWT_SECRET=generate-another-random-64-char-secret-bbbbbbbbbbbbbbbbbbbbbbbbbb

# ═══════════════════════════════════════════════════════════════════════════════
# RECOMMENDED — Review and adjust
# ═══════════════════════════════════════════════════════════════════════════════

# Server
KASRA_APP_HOST=0.0.0.0
KASRA_APP_PORT=8080
KASRA_APP_WORKERS=4
KASRA_APP_LOG_LEVEL=info

# Rate limiting
KASRA_APP_RATE_LIMIT_RPM=120

# Audit retention (auto-delete logs older than this)
KASRA_APP_AUDIT_RETENTION_DAYS=90

# HTTPS CONNECT proxy (disabled by default — enable if needed)
# KASRA_APP_HTTPS_PROXY_ENABLED=true
# KASRA_APP_HTTPS_PROXY_PORT=8443

# Allowed CORS origins (set to your domain)
KASRA_APP_ALLOWED_ORIGINS='["https://kasra.example.com"]'

# Proxy upstream targets (comma-separated)
KASRA_APP_PROXY_TARGETS=api.anthropic.com,api.openai.com,api.deepseek.com

# ═══════════════════════════════════════════════════════════════════════════════
# SDK Engine Configuration
# ═══════════════════════════════════════════════════════════════════════════════

KASRA_ENGINE__MAX_CONCURRENT_RULES=50
KASRA_AUDIT__ENABLED=true
KASRA_AUDIT__JSONL_PATH=/data/kasra-audit.jsonl

# ═══════════════════════════════════════════════════════════════════════════════
# PostgreSQL connection pool tuning (adjust based on workload)
# ═══════════════════════════════════════════════════════════════════════════════
# KASRA_APP_DATABASE_POOL_SIZE=10
# KASRA_APP_DATABASE_MAX_OVERFLOW=20
# KASRA_APP_DATABASE_POOL_RECYCLE=3600
